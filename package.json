{
  "name": "isa-spa",
  "version": "0.1.0",
  "private": true,
  "description": "ISA Spa website redesign — Next.js public site + Express/MySQL CMS API + React admin.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:admin": "pnpm --filter admin dev",
    "build": "pnpm --filter @isa/db generate && pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @isa/db generate",
    "db:migrate": "pnpm --filter @isa/db migrate",
    "db:seed": "pnpm --filter @isa/db seed",
    "db:studio": "pnpm --filter @isa/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
