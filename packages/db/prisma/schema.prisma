// ISA Spa — data model (MySQL). See packages/shared for validation schemas.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth / CMS users ───
enum Role {
  ADMIN
  EDITOR
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role     @default(EDITOR)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  assignedLeads FormSubmission[] @relation("AssignedLeads")

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Publishing ───
enum PublishStatus {
  DRAFT
  PUBLISHED
}

// ─── Spa Locator ───
model Location {
  id        Int           @id @default(autoincrement())
  name      String
  slug      String        @unique
  city      String
  area      String?
  address   String        @db.Text
  phone     String?
  whatsapp  String?
  lat       Float?
  lng       Float?
  mapUrl    String?       @map("map_url") @db.Text
  hours     Json?
  images    Json? // string[]
  order     Int           @default(0)
  status    PublishStatus @default(PUBLISHED)
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  ogImage         String? @map("og_image")
  canonical       String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([city])
  @@index([status])
  @@map("locations")
}

// ─── Services / Therapies ───
model ServiceCategory {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  tagline   String?   @db.Text
  heroImage String?   @map("hero_image")
  order     Int       @default(0)
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  services  Service[]

  @@map("service_categories")
}

model Service {
  id          Int             @id @default(autoincrement())
  categoryId  Int             @map("category_id")
  name        String
  slug        String          @unique
  duration    String? // "60 / 90 min"
  price       String? // "₹1,999"
  description String?         @db.Text
  image       String?
  order       Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("services")
}

// ─── Blog ───
model BlogPost {
  id          Int           @id @default(autoincrement())
  title       String
  slug        String        @unique
  excerpt     String?       @db.Text
  body        String        @db.LongText
  coverImage  String?       @map("cover_image")
  author      String?
  tags        Json? // string[]
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description") @db.Text
  ogImage         String?   @map("og_image")
  canonical       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@map("blog_posts")
}

// ─── Testimonials ───
model Testimonial {
  id         Int           @id @default(autoincrement())
  quote      String        @db.Text
  authorName String        @map("author_name")
  city       String?
  rating     Int?
  order      Int           @default(0)
  status     PublishStatus @default(PUBLISHED)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ─── Gallery ───
model GalleryItem {
  id        Int      @id @default(autoincrement())
  image     String
  caption   String?
  album     String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_items")
}

// ─── Careers ───
model JobOpening {
  id          Int           @id @default(autoincrement())
  title       String
  slug        String        @unique
  location    String?
  type        String? // full-time, part-time
  description String        @db.LongText
  status      PublishStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("job_openings")
}

// ─── Editable copy for otherwise-static pages (About, Membership, etc.) ───
model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String?
  blocks    Json? // structured content blocks
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

// ─── Media library ───
model Media {
  id        Int      @id @default(autoincrement())
  filename  String
  url       String   @db.Text
  mime      String
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media")
}

// ─── Unified leads / form submissions ───
enum FormType {
  APPOINTMENT
  FRANCHISE
  HOTEL
  CONTACT
  CAREER
  MEMBERSHIP
  GIFT_CARD
}

enum SubmissionStatus {
  NEW
  CONTACTED
  CLOSED
}

model FormSubmission {
  id         Int              @id @default(autoincrement())
  type       FormType
  payload    Json // validated form fields
  sourcePage String?          @map("source_page")
  status     SubmissionStatus @default(NEW)
  assignedTo Int?             @map("assigned_to")
  notes      String?          @db.Text
  ip         String?
  userAgent  String?          @map("user_agent") @db.Text
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  assignee   User?            @relation("AssignedLeads", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([createdAt])
  @@map("form_submissions")
}

// ─── Site settings (key/value) ───
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ─── 301 redirect map (preserve legacy isaspa.in URLs) ───
model Redirect {
  id        Int      @id @default(autoincrement())
  from      String   @unique
  to        String   @db.Text
  code      Int      @default(301)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("redirects")
}

// ─── Audit trail ───
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String // e.g. "location.update"
  entity    String? // e.g. "Location:12"
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@map("audit_logs")
}

// ─── AI blog generation runs (observability for the AI generator) ───
enum GenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum GenerationTrigger {
  MANUAL
  SCHEDULED
}

model BlogGenerationRun {
  id              Int               @id @default(autoincrement())
  status          GenerationStatus  @default(PENDING)
  trigger         GenerationTrigger @default(MANUAL)
  currentStep     String?           @map("current_step")
  pillar          String?
  topic           String?           @db.Text
  blogPostId      Int?              @map("blog_post_id") // set once a draft is created
  seoScore        Int?              @map("seo_score")
  qualityScore    Int?              @map("quality_score")
  retryCount      Int               @default(0) @map("retry_count")
  imageSource     String?           @map("image_source") // pexels | unsplash | none
  generationMs    Int?              @map("generation_ms")
  errorMessage    String?           @map("error_message") @db.Text
  metadata        Json? // token usage, model usage, cost estimate, structured data
  triggeredBy     Int?              @map("triggered_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("blog_generation_runs")
}
