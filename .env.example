# ─────────────────────────────────────────────────────────────
# ISA Spa — environment template. Copy to .env and fill in.
# Root .env is read by packages/db (Prisma) and apps/api.
# apps/web and apps/admin have their own .env.local (see below).
# ─────────────────────────────────────────────────────────────

# --- Database (MySQL) ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/isa_spa"

# --- API (apps/api) ---
API_PORT=4000
NODE_ENV=development
# Comma-separated allowed origins for CORS (web + admin)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# JWT secrets (generate strong random values: `openssl rand -hex 48`)
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Seed admin (created by `pnpm db:seed`)
SEED_ADMIN_EMAIL="admin@isaspa.in"
SEED_ADMIN_PASSWORD="ChangeMe!123"

# --- Lead notifications (optional in dev) ---
# SMTP for staff email alerts on new form submissions
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
LEADS_NOTIFY_TO="leads@isaspa.in"

# Cloudflare Turnstile (anti-spam on public forms) — optional in dev
TURNSTILE_SECRET=""

# --- Media storage ---
# dev: local disk (apps/api/uploads). prod: set S3/R2 vars.
MEDIA_DRIVER="local"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""

# ─── apps/web/.env.local ───
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# API_INTERNAL_URL="http://localhost:4000"   # server-side fetch (SSR/ISR)
# NEXT_PUBLIC_TURNSTILE_SITEKEY=""

# ─── apps/admin/.env.local ───
# VITE_API_URL="http://localhost:4000"

# ── AI blog generator (OpenRouter free models) ──
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_REFERER="https://isaspa.in"
OPENROUTER_TITLE="ISA Spa CMS"
# Optional per-role model overrides (defaults: Gemma-first, see services/ai-blog/models.ts)
# OPENROUTER_MODEL_WRITER="google/gemma-4-31b-it:free"
# OPENROUTER_MODEL_RESEARCHER="google/gemma-4-31b-it:free"
# OPENROUTER_MODEL_SEO="google/gemma-4-26b-a4b-it:free"
# OPENROUTER_MODEL_QUALITY="google/gemma-4-31b-it:free"
# OPENROUTER_MODEL_IMAGE_QUERY="google/gemma-4-26b-a4b-it:free"
# Free stock image keys (cover images; falls back to placeholder if unset)
PEXELS_API_KEY=""
UNSPLASH_ACCESS_KEY=""
# Scheduler (off by default). Cron is standard 5-field; default weekly Mon 03:00.
AI_BLOG_ENABLED="false"
AI_BLOG_CRON="0 3 * * 1"
AI_BLOG_MIN_QUALITY="70"
AI_BLOG_MAX_RETRIES="1"
